<% content_for :title, "Grafo de Red de #{@patron.name} - Jardín LAC Vizcaínas" %>

<div style="margin-bottom:1.5rem; display:flex; justify-content:space-between; align-items:center;">
  <a href="<%= user_path(@patron.id) %>" class="btn btn-secondary" style="padding:0.4rem 0.8rem; font-size:0.85rem; font-weight:600;">
    <i class="fa-solid fa-arrow-left"></i> Volver a Recomendaciones
  </a>
</div>

<div class="glass-card" style="margin-bottom:1.5rem;">
  <div style="display:flex; align-items:center; gap:1rem;">
    <i class="fa-solid fa-diagram-project" style="font-size:2rem; color:var(--color-accent);"></i>
    <div>
      <h1 style="font-family:var(--font-display); font-size:1.75rem; font-weight:700; margin:0; color:var(--text-primary);">
        Grafo de Afinidad y Red de Lectura: <%= @patron.name %>
      </h1>
      <p style="font-size:0.85rem; color:var(--text-secondary); margin-top:0.2rem;">
        Visualización topológica interactiva de lectores afines, préstamos compartidos y recomendaciones colaborativas.
      </p>
    </div>
  </div>
</div>

<div class="graph-split" data-controller="d3-user-graph" data-d3-user-graph-url-value="<%= api_user_graph_path(@patron.id) %>">
  <!-- D3 Canvas Card -->
  <div class="glass-card" style="padding:0; position:relative; overflow:hidden; min-height:550px; display:flex; flex-direction:column;">
    <div id="graph-container" data-d3-user-graph-target="container" style="width:100%; height:550px; background:var(--bg-primary);"></div>
    
    <!-- Legend Footer -->
    <div class="graph-legend" style="padding:0.75rem 1.25rem; background:white; border-top:1px solid var(--border-light); display:flex; gap:1.25rem; flex-wrap:wrap; font-size:0.75rem; align-items:center;">
      <div style="display:flex; align-items:center; gap:0.4rem;">
        <span style="width:12px; height:12px; border-radius:50%; background:#f43f5e; display:inline-block;"></span> Lector Principal
      </div>
      <div style="display:flex; align-items:center; gap:0.4rem;">
        <span style="width:10px; height:10px; border-radius:50%; background:#56697a; display:inline-block;"></span> Préstamo Propio
      </div>
      <div style="display:flex; align-items:center; gap:0.4rem;">
        <span style="width:11px; height:11px; border-radius:50%; background:#52755e; display:inline-block;"></span> Lector Afin
      </div>
      <div style="display:flex; align-items:center; gap:0.4rem;">
        <span style="width:9px; height:9px; border-radius:50%; background:#b38f4d; display:inline-block;"></span> Recomendación Colaborativa
      </div>
    </div>
  </div>

  <!-- Side Inspector Panel -->
  <div class="glass-card" data-d3-user-graph-target="panel" style="overflow-y:auto; max-height:600px;">
    <div style="text-align:center; padding:4rem 1.5rem; color:var(--text-secondary);">
      <i class="fa-solid fa-hand-pointer" style="font-size:2.5rem; color:var(--text-muted); opacity:0.4; margin-bottom:0.75rem;"></i>
      <p style="font-size:1rem; font-weight:600;">Selecciona un nodo del grafo</p>
      <p style="font-size:0.8rem; color:var(--text-muted);">Haz clic en cualquier lector u obra para inspeccionar sus conexiones y métricas.</p>
    </div>
  </div>
</div>
